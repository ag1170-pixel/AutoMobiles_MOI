h1,h2,h3
{ 
 font-family: verdana;
 font-size: 22px;
 font-weight: bold;
}

h2
{ 
 font-size: 16px;
 font-weight: bold;
}

h3
{ 
 font-size: 12px;
 font-weight: bold;
}

.footerlinks{font-family:verdana;font-size:11px;font-weight:normal;color:white;text-decoration:none;}
.footerlinks:hover{font-family:verdana;font-size:11px;font-weight:normal;color:#EFD700;text-decoration:none;}

.toplinks{font-family:verdana;color:#383438;font-size:11px;font-weight:bold;text-decoration:none;}
.toplinks:hover{font-family:verdana;color:brown;font-size:11px;font-weight:bold;text-decoration:none;}

.leftpanellinks{font-family:arial;font-size:11px;color:white;text-decoration:none;font-weight:bold;}
.leftpanellinks:hover{font-family:arial;font-size:11px;color:silver;text-decoration:none;font-weight:bold;}

.leftpanellinks1{font-family:arial;font-size:10px;color:white;text-decoration:none;font-weight:bold;}
.leftpanellinks1:hover{font-family:arial;font-size:10px;color:silver;text-decoration:none;font-weight:bold;}

.indextext{font-family:verdana;color:#18185A;font-weight:bold;font-size:12px;text-decoration:none;}
.indextext:hover{font-family:verdana;color:white;background-color:#18185A;font-weight:bold;font-size:12px;text-decoration:none;}

.pathlink{font-family:verdana;font-size:11px;color:#18185A;text-decoration:none;font-weight:bold;}
.pathlink:hover{font-family:verdana;font-size:11px;color:#18185A;text-decoration:underline;font-weight:bold;}

.cement{font-family:verdana;font-size:11px;color:navy}

.text{font-family:verdana;font-size:11px;}

.heading{font-family:verdana;font-size:12px;font-weight:bold;color:#18185A;}