					 <div class="ContentText">
					 	<table align="right" border="0" cellspacing="0" cellpadding="0">
							<tr>
								<td style="width: 4px"></td>
								<td valign=top>
								<script type="text/javascript"><!--
								google_ad_client = "pub-0641096029648877";
								google_ad_width = 160;
